th2 description 'servers-net'\n\n  # --- IPv4 ---\n  - delete interfaces ethernet eth2 address 'dhcp'\n  - set interfaces ethernet eth2 address '10.20.100.254/24'\n\n  # --- IPv6 ---\n  - delete interfaces ethernet eth2 address 'dhcpv6'\n  # Interface eth3\n  - set interfaces ethernet eth3 description 'clientes_ti-net'\n\n  # --- IPv4 ---\n  - delete interfaces ethernet eth3 address 'dhcp'\n  - set interfaces ethernet eth3 address '10.20.10.254/24'\n\n  # --- IPv6 ---\n  - delete interfaces ethernet eth3 address 'dhcpv6'\n  # Interface eth4\n  - set interfaces ethernet eth4 description 'clientes_fin-net'\n\n  # --- IPv4 ---\n  - delete interfaces ethernet eth4 address 'dhcp'\n  - set interfaces ethernet eth4 address '10.20.11.254/24'\n\n  # --- IPv6 ---\n  - delete interfaces ethernet eth4 address 'dhcpv6'\n\n  # --- Gateway ---\n  - set protocols static route 0.0.0.0/0 next-hop '10.21.1.2'\n\n"},"sensitive_attributes":[],"dependencies":["module.orchestration.module.network.libvirt_network.this","module.orchestration.module.volume.libvirt_volume.this"]},{"index_key":"Nfirewall03","schema_version":0,"attributes":{"id":"0d98c44a76e8a0ea","meta_data":"","name":"Nfirewall03-cloudinit","network_config":"version: 2\nethernets:\n  eth0:\n    dhcp4: false\n    dhcp6: false\n  eth1:\n    dhcp4: false\n    dhcp6: false\n","path":"/tmp/terraform-provider-libvirt-cloudinit/cloudinit-0d98c44a76e8a0ea.iso","size":43008,"user_data":"#cloud-config\nvyos_config_commands:\n  # Hostname\n  - set system host-name 'nfirewall03'\n\n  # Usuário com chave SSH\n  - set system login user ansible authentication encrypted-password '$6$hTsm9OSnl0JnaIL/$h.UQHqWJaUkU9TEDrZ13xfkampt5imBmM7eap60MIW79cgE.qXj/JDv20RtbDM1iDFoR7UW8VWDJ1xIGQ9LMh.'\n  - set system login user ansible authentication public-keys ansible_key.pub key ''\n  - set system login user ansible authentication public-keys ansible_key.pub type 'ssh-rsa'\n\n  # Interface eth0\n  - set interfaces ethernet eth0 description 'wan-net'\n\n  # --- IPv4 ---\n  - set interfaces ethernet eth0 address 'dhcp'\n\n  # --- IPv6 ---\n  - set interfaces ethernet eth0 address 'dhcpv6'\n  # Interface eth1\n  - set interfaces ethernet eth1 description 'uplink-net'\n\n  # --- IPv4 ---\n  - delete interfaces ethernet eth1 address 'dhcp'\n  - set interfaces ethernet eth1 address '10.21.1.2/29'\n\n  # --- IPv6 ---\n  - delete interfaces ethernet eth1 address 'dhcpv6'\n\n  # --- Gateway ---\n\n  # --- Configuração de Firewall/NAT ---\n  \n  # Habilitar forwarding IP\n  - set system ip forwarding\n  \n  # Configurar NAT (masquerade) para todas as redes internas\n  - set nat source rule 10 outbound-interface name 'eth0'\n  - set nat source rule 10 translation address 'masquerade'\n  \n  # Rotas de retorno para redes internas\n  - set protocols static route 10.20.200.0/24 next-hop '10.21.1.3'\n  - set protocols static route 10.20.100.0/24 next-hop '10.21.1.3'\n  - set protocols static route 10.20.10.0/24 next-hop '10.21.1.3'\n  - set protocols static route 10.20.11.0/24 next-hop '10.21.1.3'\n  \n"},"sensitive_attributes":[],"dependencies":["module.orchestration.module.network.libvirt_network.this","module.orchestration.module.volume.libvirt_volume.this"]},{"index_key":"SansibleSVR03","schema_version":0,"attributes":{"id":"fb63138999fd383d","meta_data":"instance-id: SansibleSVR03\nlocal-hostname: SansibleSVR03\n","name":"SansibleSVR03-cloudinit","network_config":"network:\n  version: 2\n  ethernets:\n    enp1s0:\n      dhcp4: false\n      dhcp6: false\n      addresses:\n        - 10.20.100.20/24\n      routes:\n        - to: 0.0.0.0/0\n          via: 10.20.100.254\n      nameservers:\n        addresses: [\"8.8.8.8\"]\n","path":"/tmp/terraform-provider-libvirt-cloudinit/cloudinit-fb63138999fd383d.iso","size":47104,"user_data":"#cloud-config\n\nssh_pwauth: true\n\nhostname: sansiblesvr03\nfqdn: sansiblesvr03.teste.local\n\nmanage_etc_hosts: true\n\n\n#chpasswd:\n#  list: |\n#    root:$6$icCsrgPFmUJ7y40/$2TligMlpR5P2FiFsjrxNZmmYsBmOkpd0sJ4Am/8x6Ko8grcjVf08ZKeUPgiGaNohkZSJrtqVCLKBxGZ6vDY4e1\n#  expire: false\n\n\nusers:\n  - name: ansible\n    gecos: \"Usuário de Laboratório\"\n    groups: [wheel, sudo, admin]\n    shell: /bin/bash\n    sudo: \"ALL=(ALL) NOPASSWD:ALL\"\n    lock_passwd: false\n    passwd: \"$6$hTsm9OSnl0JnaIL/$h.UQHqWJaUkU9TEDrZ13xfkampt5imBmM7eap60MIW79cgE.qXj/JDv20RtbDM1iDFoR7UW8VWDJ1xIGQ9LMh.\"\n    ssh_authorized_keys:\n      - ssh-rsa  mdonato@aesthar\n\npackage_update: true\n#package_upgrade: true\n\ntimezone: America/Sao_Paulo\nlocale: en_US.UTF-8\nkeyboard:\n  layout: br\n  model: pc105\n  variant: abnt2\n\npackages:\n  - vim\n  - curl\n  - wget\n  - net-tools\n  - git\n  - tmux\n  - qemu-guest-agent\n  - bash-completion\n  - python3\n  - ansible\n  - python3-pip\n  - python3-devel\n  - python3-paramiko\n  - gcc\n  - libssh-devel\n\n\nruncmd:\n  - [ systemctl, enable, --now, qemu-guest-agent.service ]\n  - [ timedatectl, set-timezone, America/Sao_Paulo ]\n  - |\n    #!/bin/bash\n    if [-f /etc/redhat-release ]; then\n      localectl set-locale LANG=en_US.UTF-8\n      localectl set-keymap br-abnt2\n    fi\n  - [ git, clone, https://github.com/donato-marcos/TCC_ansible.git, /home/ansible/ansible]\n  - [ chown, -R, ansible:ansible, /home/ansible/ansible ]\n  - [ pip, install, pywinrm, ansible-pylibssh ]\n  - [ sudo, -u, ansible, ssh-keygen, -t, rsa, -b, \"2048\", -f, /home/ansible/.ssh/ansible_key, -N, \"\" ]\n  - |\n    cat \u003c\u003c 'EOF' \u003e /home/ansible/.tmux.conf\n    set -g prefix ^B\n    set -g renumber-windows on\n    set -g base-index 1\n    set-option -g mouse on\n    set-option -g status-position top\n\n    bind-key -n M-a setw synchronize-panes on\n    bind-key -n M-d setw synchronize-panes off\n\n    set -g window-status-activity-style bg=red\n    set -g window-status-current-format \"#{?pane_synchronized,[SYNC] ,}#I:#W\"\n    EOF\n  - [ chown, ansible:ansible, /home/ansible/.tmux.conf ]\n\n"},"sensitive_attributes":[],"dependencies":["module.orchestration.module.network.libvirt_network.this","module.orchestration.module.volume.libvirt_volume.this"]}]},{"module":"module.orchestration.module.cloudinit","mode":"managed","type":"libvirt_volume","name":"cloudinit_iso","provider":"provider[\"registry.opentofu.org/dmacvicar/libvirt\"]","instances":[{"index_key":"Ncore03","schema_version":0,"attributes":{"allocation":45056,"allocation_unit":null,"backing_store":null,"capacity":45056,"capacity_unit":null,"create":{"content":{"url":"/tmp/terraform-provider-libvirt-cloudinit/cloudinit-10c601cdb448cab1.iso"}},"id":"/home/mdonato/vm/Ncore03-cloudinit.iso","key":"/home/mdonato/vm/Ncore03-cloudinit.iso","name":"Ncore03-cloudinit.iso","path":"/home/mdonato/vm/Ncore03-cloudinit.iso","physical":45056,"physical_unit":null,"pool":"default","target":null,"type":null},"sensitive_attributes":[],"dependencies":["module.orchestration.module.cloudinit.libvirt_cloudinit_disk.this","module.orchestration.module.network.libvirt_network.this","module.orchestration.module.volume.libvirt_volume.this"]},{"index_key":"Nfirewall03","schema_version":0,"attributes":{"allocation":45056,"allocation_unit":null,"backing_store":null,"capacity":43008,"capacity_unit":null,"create":{"content":{"url":"/tmp/terraform-provider-libvirt-cloudinit/cloudinit-0d98c44a76e8a0ea.iso"}},"id":"/home/mdonato/vm/Nfirewall03-cloudinit.iso","key":"/home/mdonato/vm/Nfirewall03-cloudinit.iso","name":"Nfirewall03-cloudinit.iso","path":"/home/mdonato/vm/Nfirewall03-cloudinit.iso","physical":43008,"physical_unit":null,"pool":"default","target":null,"type":null},"sensitive_attributes":[],"dependencies":["module.orchestration.module.cloudinit.libvirt_cloudinit_disk.this","module.orchestration.module.network.libvirt_network.this","module.orchestration.module.volume.libvirt_volume.this"]},{"index_key":"SansibleSVR03","schema_version":0,"attributes":{"allocation":49152,"allocation_unit":null,"backing_store":null,"capacity":47104,"capacity_unit":null,"create":{"content":{"url":"